# 环境变量模板
# 复制到 .env.development 或 .env.production 后填写真实值。

# 必填：DApp 模式。development 使用本地 Hardhat 链；production 使用正式 DOR Network。
NEXT_PUBLIC_APP_MODE=development

# 必填：SHDStaking/DApp 入口合约地址。前端会通过该合约读取 SHD token 地址。
NEXT_PUBLIC_DAPP_ADDRESS=0x0000000000000000000000000000000000000000

# 可选：产品包购买链上扣款成功后的商城服务端回调。
# 不配置时，接口会返回 skipped，但链上扣款交易仍已完成。
MALL_CALLBACK_URL=
MALL_CALLBACK_SECRET=

# 正式部署合约时，复制 .env.hardhat.example 为 .env.hardhat 并填写 RPC / chainId / 私钥 / SHD 地址。